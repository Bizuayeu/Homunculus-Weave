#!/bin/bash

# Identities/ 配下ファイルの自動同期スクリプト

# WeaveIdentity.md の同期（BusinessAnalyzerスキル用参照コピー）
SOURCE_IDENTITY="Identities/WeaveIdentity.md"
TARGET_IDENTITY="Expertises/CorporateStrategist/BusinessAnalyzer/References/WeaveIdentity.md"

if git diff --cached --name-only | grep -q "^${SOURCE_IDENTITY}$"; then
    echo "🔄 Syncing WeaveIdentity.md..."
    cp "${SOURCE_IDENTITY}" "${TARGET_IDENTITY}"
    git add "${TARGET_IDENTITY}"
    echo "✅ Synced: ${TARGET_IDENTITY}"
fi

# MSP_Practice_Manual.md の同期
SOURCE_MSP="Identities/MSP_Practice_Manual.md"
TARGET_MSP="Expertises/CorporateStrategist/BusinessAnalyzer/References/MSP_Practice_Manual.md"

if git diff --cached --name-only | grep -q "^${SOURCE_MSP}$"; then
    echo "🔄 Syncing MSP_Practice_Manual.md..."
    cp "${SOURCE_MSP}" "${TARGET_MSP}"
    git add "${TARGET_MSP}"
    echo "✅ Synced: ${TARGET_MSP}"
fi

exit 0

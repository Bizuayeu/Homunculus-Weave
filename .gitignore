# システムファイル
.DS_Store
Thumbs.db
desktop.ini

# 一時ファイル
*.tmp
*.temp
*.log
.temp/

# 認証情報
.git-credentials

# IDE
.vscode/
.idea/

# Python関連
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
.pytest_cache/
# pytest 出力をリダイレクトした手動実行の残骸（例: pytest > _pytest_out.txt）
_pytest_out.txt
.coverage
htmlcov/
*.egg-info/
dist/
build/

# テストは信頼性証拠として全 Expertises で公開する方針
# __pycache__ / *.pyc / .pytest_cache は上の Python 関連ブロックで除外済み

# ランタイム生成 state（offset.json / lease.json 等、Expertise ごとの実行時データ）
Expertises/*/state/

# EpisodicRAGなど - プライベート管理のため非公開
.claude/agents/digest-analyzer.md
EpisodicRAG/
EpisodicWiki/
BusinessWiki/
Expertises/BlueberrySprite/

# PrivateLibrarian - 機密ナレッジ全体を非公開
Expertises/PrivateLibrarian/

# PrecognitiveViewer - 鑑定書出力は受け手プライベート、リポ非管理
Expertises/PrecognitiveViewer/Report/outputs/


# TelegramSecretary は plugins-weave 実体への junction（ローカル透過、配布実体は plugins-weave）
Expertises/TelegramSecretary

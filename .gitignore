.git-credentials

# IDE
.vscode/
.idea/

# Python関連
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
.pytest_cache/
.coverage
htmlcov/
*.egg-info/
dist/
build/

# テストフォルダ（ローカル開発用）
**/test/
**/tests/

# EpisodicRAGなど - プライベート管理のため非公開
.claude/agents/digest-analyzer.md
EpisodicRAG/
EpisodicWiki/
BusinessWiki/
Expertises/BlueberrySprite/

# PrivateLibrarian - 機密ナレッジ全体を非公開
Expertises/PrivateLibrarian/

# PrecognitiveViewer - tests/ は信頼性証拠として公開（**/tests/ ルールの例外）
!Expertises/PrecognitiveViewer/tests/
!Expertises/PrecognitiveViewer/tests/**
# ただし __pycache__/ や .pyc は再除外（汎用 Python ルール尊重）
Expertises/PrecognitiveViewer/tests/__pycache__/
Expertises/PrecognitiveViewer/**/__pycache__/
Expertises/PrecognitiveViewer/**/*.pyc
# 鑑定書出力は受け手プライベート、リポ非管理
Expertises/PrecognitiveViewer/Report/outputs/


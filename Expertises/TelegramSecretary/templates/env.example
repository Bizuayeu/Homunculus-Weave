# TelegramSecretary — 環境変数の雛型
#
# このファイルをコピーし、<...> を自分の値に置換して使う。
# secrets（BOT_TOKEN 等）はコミットしないこと（実体は <PRIVATE_DIR> 側 or Environment 注入）。
# 既定値で動く optional 項目はコメントアウトのまま。プレースホルダ規約は STRUCTURE.md 参照。

# ===== 必須 =====

# BotFather から取得した bot token
TELEGRAM_BOT_TOKEN=<your-bot-token>

# 認可する chat_id の JSON 配列（allowlist）。例: [123456789]
# 鶏卵問題ゆえ初回のみ手動取得（README の chat_id 発見手順を参照）
TELEGRAM_SECRETARY_AUTHORIZED_CHATS=[<your-chat-id>]

# ===== 非秘匿の運用設定は config.json（env ではない）=====
# session_duration_sec / agent_name / private_dir は <INSTALL_DIR>/config.json に置く。
# 雛型 templates/config.template.json をコピーするか `python scripts/main.py init-config` で生成。
# env は秘匿（上記）+ state_dir のみ＝純2層。

# ===== 任意（既定値あり）=====

# 揮発 state（offset/lease/media）の保存先。既定 ./state（bootstrap が <INSTALL_DIR>/state に絶対化）。
# 消えてよい揮発データ専用（offset は Telegram の ~24h 保持で取りこぼさず、lease は再取得、media は retention 削除）。
# TELEGRAM_SECRETARY_STATE_DIR=<INSTALL_DIR>/state

# 永続管理表（individuals/tasks/knowledge）の git 永続化設定（registry_sync / registry_dir /
# registry_branch / registry_remote）は config.json 側が正典（雛型 templates/config.template.json）。
# 非秘匿の運用設定ゆえ env ではなく config.json（fresh clone が読む）。

# リース owner ID。省略時は bootstrap が uuid 自動生成
# TELEGRAM_SECRETARY_SESSION_ID=

# 受信 media download のサイズ上限（既定 20MB = 20971520）
# TELEGRAM_SECRETARY_MEDIA_MAX_SIZE_BYTES=20971520

# 保存 media の保持期限（時間、既定 24）
# TELEGRAM_SECRETARY_MEDIA_RETENTION_HOURS=24

# Heavy（true=既定、media 保存＋render）/ Medium（false、メタのみ・軽量）
# TELEGRAM_SECRETARY_MEDIA_ENABLE_DOWNLOAD=true

# 音声/動画 STT（moonshine+av）を bootstrap で導入するか（既定 true）。
# 年商 $1M 以上は moonshine Community License 回避のため false 推奨（音声は skipped にフォールバック）
# TELEGRAM_SECRETARY_BUNDLE_VOICE=true

# 送信添付の上限（既定 50MB = 52428800、Telegram bot API 上限）
# TELEGRAM_SECRETARY_OUTBOUND_MAX_SIZE_BYTES=52428800

# PDF 受信時に事前画像化する先頭ページ数の上限（既定 20）
# TELEGRAM_SECRETARY_PDF_IMAGE_MAX_PAGES=20
